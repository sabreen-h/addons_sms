    </template>


 <!-- Displaying the course details -->
<template id="portal_instructor_course_details" name="course_detail">
    <t t-call="portal.portal_layout">
        <div class="container py-5">
            <div class="card shadow-lg border-0 rounded-lg overflow-hidden">
                <!-- Header Section -->
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0 font-weight-bold">
                        <span class="mr-2">🏫</span>Course Details
                    </h3>
                </div>

                <!-- Body Section -->
                <div class="card-body p-5 bg-light">
                    <div class="row align-items-stretch">
                        <!-- Course Image -->
                        <div class="col-md-4 pr-0">
                            <div class="course-image-frame h-100">
                                <img t-att-src="'/web/image/sms_module.course/' + str(course.id) + '/image'"
                                    class="course-image img-fluid rounded-left"
                                    alt="Course Image"
                                    style="width: 100%; object-fit: contain; min-height: 400px;"/>
                            </div>
                        </div>

                        <!-- Course Information -->
                        <div class="col-md-8">
                            <div class="table-responsive">
                                <table class="table table-striped table-hover align-middle border-0">
                                    <!-- Course details table content goes here -->
                                    <tbody>
    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">📖 Syllabus</th>
        <td class="py-3 text-dark"><span t-field="course.syllabus"/></td>
    </tr>

    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">⏳ Duration</th>
        <td class="py-3 text-dark"><span t-field="course.duration"/> hours</td>
    </tr>

    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">📋 Prerequisites</th>
        <td class="py-3 text-dark"><span t-field="course.prerequisites"/></td>
    </tr>

    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">⭐ Featured</th>
        <td class="py-3 text-dark">
            <t t-if="course.is_featured">Yes</t>
            <t t-else="">No</t>
        </td>
    </tr>

    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">📚 Course Level</th>
        <td class="py-3 text-dark"><span t-field="course.course_level"/></td>
    </tr>

    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">👨‍🎓 Enrolled Students</th>
        <td class="py-3 text-dark"><span t-field="course.enrollment_count"/></td>
    </tr>

    <tr>
        <th class="bg-white text-primary py-3 font-weight-bold">🎯 Completion Percentage</th>
        <td class="py-3 text-dark"><span t-field="course.completion_percentage"/>%</td>
    </tr>
</tbody>

                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</template>

</odoo>
